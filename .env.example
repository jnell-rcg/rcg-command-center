# ============================================================
# RCG Command Center — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Google OAuth (Gmail + Calendar) ---
# Create credentials at https://console.cloud.google.com
# Scopes needed: gmail.readonly, calendar.readonly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# --- Slack ---
# Create a Bot Token at https://api.slack.com/apps
# Scopes needed: channels:history, channels:read, users:read
SLACK_BOT_TOKEN=xoxb-...
# Comma-separated list of channel IDs to monitor (e.g. C01234567,C09876543)
SLACK_CHANNEL_IDS=
